---
interface Issue {
  title: string;
  description?: string;
  severity?: "critical" | "major" | "minor";
  since?: string;
  link?: string;
  linkLabel?: string;
}

interface Props {
  issues?: Issue[];
  heading?: string;
}

const { issues, heading = "Known Issues" } = Astro.props;

if (!issues || issues.length === 0) return null;

const severityLabel: Record<string, string> = {
  critical: "Critical",
  major: "Major",
  minor: "Minor",
};

function formatSince(since?: string): string | null {
  if (!since) return null;
  const d = new Date(since);
  if (Number.isNaN(d.getTime())) return since;
  return d.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
}

function linkify(text: string): string {
  return text.replace(
    /(https?:\/\/[^\s<>"')\]]+)/g,
    '<a href="$1" class="issue__inline-link">$1</a>',
  );
}
---

<section class="known-issues">
  <details class="known-issues__details">
    <summary class="known-issues__summary">
      <h2 class="known-issues__heading">{heading}</h2>
      <span class="known-issues__count">{issues.length}</span>
      <span class="known-issues__chevron" aria-hidden="true" />
    </summary>
    <ul class="known-issues__list">
      {issues.map((issue) => {
        const sinceLabel = formatSince(issue.since);
        return (
          <li class="issue">
            <div class="issue__header">
              <h3 class="issue__title">{issue.title}</h3>
              {issue.severity && (
                <span class="issue__severity" data-severity={issue.severity}>
                  {severityLabel[issue.severity] ?? issue.severity}
                </span>
              )}
            </div>
            {issue.description && <p class="issue__description" set:html={linkify(issue.description)} />}
            {(sinceLabel || issue.link) && (
              <div class="issue__meta">
                {sinceLabel && <span class="issue__since">Since {sinceLabel}</span>}
                {issue.link && (
                  <a class="issue__link" href={issue.link}>
                    {issue.linkLabel ?? "More info"}
                  </a>
                )}
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </details>
</section>

<style>
  .known-issues {
    margin-top: var(--space-2xl);
  }

  .known-issues__details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-surface);
    box-shadow: var(--shadow-sm);
  }

  .known-issues__summary {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .known-issues__summary::-webkit-details-marker {
    display: none;
  }

  .known-issues__heading {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .known-issues__count {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 8px;
    border-radius: var(--radius-full);
    background: var(--color-red-bg);
    color: var(--color-red);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
  }

  .known-issues__chevron {
    width: 20px;
    height: 20px;
    transition: transform 0.2s ease;
    background: none;
    position: relative;
  }

  .known-issues__chevron::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: translate(-50%, -65%) rotate(45deg);
    transition: transform 0.2s ease;
  }

  .known-issues__details[open] .known-issues__chevron::before {
    transform: translate(-50%, -35%) rotate(-135deg);
  }

  .known-issues__list {
    list-style: none;
    padding: 0 var(--space-lg) var(--space-lg);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .issue {
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--color-border);
    border-left-width: 4px;
    border-radius: var(--radius-md);
    background: var(--color-bg);
  }

  .issue:has(.issue__severity[data-severity="critical"]) {
    border-left-color: var(--color-red);
  }

  .issue:has(.issue__severity[data-severity="major"]) {
    border-left-color: var(--color-yellow);
  }

  .issue:has(.issue__severity[data-severity="minor"]) {
    border-left-color: var(--color-gray);
  }

  .issue__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .issue__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .issue__severity {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.6;
    white-space: nowrap;
  }

  .issue__severity[data-severity="critical"] {
    background: var(--color-red-bg);
    color: var(--color-red);
  }

  .issue__severity[data-severity="major"] {
    background: var(--color-yellow-bg);
    color: var(--color-yellow);
  }

  .issue__severity[data-severity="minor"] {
    background: var(--color-gray-bg);
    color: var(--color-gray);
  }

  .issue__description {
    margin-top: var(--space-sm);
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .issue__meta {
    margin-top: var(--space-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .issue__link {
    color: var(--color-brand-primary);
    text-decoration: none;
  }

  .issue__link:hover {
    text-decoration: underline;
  }

  .issue__inline-link {
    color: var(--color-brand-primary);
    text-decoration: none;
    word-break: break-all;
  }

  .issue__inline-link:hover {
    text-decoration: underline;
  }
</style>
