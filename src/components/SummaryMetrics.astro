---
interface Task {
  status: string;
}

interface Activity {
  tasks: Task[];
}

interface Props {
  activities: Activity[];
}

const { activities } = Astro.props;

const totalActivities = activities.length;
const allTasks = activities.flatMap((a) => a.tasks);
const totalTasks = allTasks.length;
const completedTasks = allTasks.filter((t) => t.status === "completed").length;
const blockedTasks = allTasks.filter((t) => t.status === "blocked").length;
const progressPercent = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;
---

<div class="metrics">
  <div class="metric-card">
    <span class="metric-card__value">{totalActivities}</span>
    <span class="metric-card__label">Activities</span>
  </div>
  <div class="metric-card">
    <span class="metric-card__value">{totalTasks}</span>
    <span class="metric-card__label">Tasks</span>
  </div>
  <div class="metric-card">
    <span class="metric-card__value">{progressPercent}%</span>
    <span class="metric-card__label">Complete</span>
  </div>
  <div class="metric-card" data-highlight={blockedTasks > 0 ? "red" : undefined}>
    <span class="metric-card__value">{blockedTasks}</span>
    <span class="metric-card__label">Blocked</span>
  </div>
</div>

<style>
  .metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-md);
    margin: var(--space-xl) 0;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg) var(--space-md);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .metric-card[data-highlight="red"] {
    border-color: var(--color-red);
  }

  .metric-card__value {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
  }

  .metric-card[data-highlight="red"] .metric-card__value {
    color: var(--color-red);
  }

  .metric-card__label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }
</style>
