---
interface Props {
  companyName?: string;
  logoUrl?: string;
}

const { companyName, logoUrl } = Astro.props;
---

{(companyName || logoUrl) && (
  <header class="site-header">
    <div class="site-header-inner container">
      {logoUrl && <img src={logoUrl} alt={companyName ? `${companyName} logo` : 'Company logo'} class="site-logo" />}
      {companyName && <span class="site-company-name">{companyName}</span>}
    </div>
  </header>
)}

<style>
  .site-header {
    background-color: var(--color-brand-secondary);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .site-logo {
    height: 60px;
    width: auto;
  }

  .site-company-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }
</style>
