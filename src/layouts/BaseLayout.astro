---
interface Props {
  title: string;
  description: string;
  brandPrimary?: string;
  brandSecondary?: string;
}

const { title, description, brandPrimary, brandSecondary } = Astro.props;
const brandStyle = [
  brandPrimary && `--color-brand-primary: ${brandPrimary}`,
].filter(Boolean).join('; ') || undefined;
---

<!doctype html>
<html lang="en" style={brandStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
